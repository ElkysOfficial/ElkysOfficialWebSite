# Variaveis de ambiente do projeto Elkys (frontend)
#
# COMO USAR:
#   1. Copie este arquivo para `.env` (que e .gitignore'd)
#   2. Preencha com os valores reais do seu projeto Supabase
#   3. NUNCA commite o arquivo `.env` resultante
#
# IMPORTANTE: variaveis com prefixo VITE_ vao para o bundle do
# navegador. So coloque aqui o que e seguro ser publico (anon key,
# project URL, public keys de SDKs do tipo EmailJS). Secrets reais
# (service_role, SMTP password, FTP password, webhook tokens) ficam
# em GitHub Secrets para o CI/CD ou em Edge Function secrets.

# --- Supabase (publicos por design - protegidos por RLS) ---
VITE_SUPABASE_URL="https://seu-projeto.supabase.co"
VITE_SUPABASE_PROJECT_ID="seu-projeto"
VITE_SUPABASE_PUBLISHABLE_KEY="sua-anon-key-aqui"

# --- EmailJS (formulario de contato publico) ---
# Obter em https://dashboard.emailjs.com/admin/account
# Configurar dominio whitelist no EmailJS para evitar abuso da public key
VITE_EMAILJS_SERVICE_ID="service_xxxxxxx"
VITE_EMAILJS_TEMPLATE_ID="template_xxxxxxx"
VITE_EMAILJS_AUTO_REPLY_TEMPLATE_ID="template_xxxxxxx"
VITE_EMAILJS_PUBLIC_KEY="xxxxxxxxxxxxxxxx"

# --- Build / dev ---
# Liga sourcemap em build de producao (default off para nao expor codigo).
# So use ad-hoc para debugar stack traces de libs minificadas.
# VITE_SOURCEMAP=true

# Override do badge de ambiente exibido no portal admin. Aceita: dev | staging | prod
# Default: deduzido de import.meta.env.MODE
# VITE_ENV=dev
