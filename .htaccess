# ====================================
# Elkys — Apache Configuration (Hostinger)
# ====================================

<IfModule mod_rewrite.c>
  RewriteEngine On

  # ---- 1. Dominio canonico + HTTPS ----
  # Ordem importa: www/dominio-incorreto primeiro evita double-hop quando o
  # cliente entra via http://www.elkysb.com.br → 1 unico 301 para https://elkys.com.br/

  # elkysb.com.br → elkys.com.br (dominio digitado errado)
  RewriteCond %{HTTP_HOST} ^(www\.)?elkysb\.com\.br$ [NC]
  RewriteRule ^(.*)$ https://elkys.com.br/$1 [R=301,L]

  # www → non-www
  RewriteCond %{HTTP_HOST} ^www\.elkys\.com\.br$ [NC]
  RewriteRule ^(.*)$ https://elkys.com.br/$1 [R=301,L]

  # Forcar HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # ---- 2. Remover trailing slash (exceto raiz) ----
  # Elimina duplicata /cases vs /cases/ que o Search Console marcava como
  # "Pagina alternativa com tag canonica adequada".
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} ^(.+)/$
  RewriteRule ^ %1 [R=301,L]

  # ---- 3. SPA rewrite LIMITADO a /portal/* ----
  # Rotas publicas sao pre-renderizadas (dist/<rota>/index.html) e servidas
  # diretamente pelo Apache DirectoryIndex — nao entram aqui. Portal (auth)
  # cai no React Router via index.html porque tem rotas dinamicas (/portal/
  # admin/clients/:id) que nao podem ser pre-geradas.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^portal(/.*)?$ /index.html [L]
</IfModule>

# ---- 4. Portal nao deve ser indexado ----
# Mesmo servindo index.html (com canonical apontando para home), o
# X-Robots-Tag a nivel HTTP impede indexacao de qualquer URL sob /portal/.
<IfModule mod_headers.c>
  <IfModule mod_setenvif.c>
    SetEnvIf Request_URI "^/portal" IS_PORTAL
    Header set X-Robots-Tag "noindex, nofollow" env=IS_PORTAL
  </IfModule>
</IfModule>

# ---- 5. 404 real para URLs desconhecidas ----
# Substitui o soft 404 anterior (qualquer URL invalida virava HTML da home
# com status 200, que o Google classificava como "Rastreada, mas nao
# indexada"). Agora URLs nao-existentes retornam 404 + pagina com noindex.
ErrorDocument 404 /404.html

# ====================================
# Seguranca
# ====================================

Options -Indexes

<FilesMatch "^\.">
  Order allow,deny
  Deny from all
</FilesMatch>

<FilesMatch "\.(env|log|sql|yml|yaml)$">
  Order allow,deny
  Deny from all
</FilesMatch>

# ====================================
# Compressao
# ====================================

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# ====================================
# Cache
# ====================================

<IfModule mod_expires.c>
  ExpiresActive On

  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"

  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"

  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"

  # HTML sempre revalida: evita servir index.html cacheado que referencia
  # chunks JS ja deletados pelo dangerous-clean-slate do deploy.
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(woff2?|ttf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(jpe?g|png|webp|svg|ico|gif|avif)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
  </FilesMatch>
</IfModule>

# ====================================
# Headers de seguranca
# ====================================

<IfModule mod_headers.c>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
</IfModule>
