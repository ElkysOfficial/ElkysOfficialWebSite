# ====================================
# Elkys — Apache Configuration (Hostinger)
# ====================================

# ---- 0. Identificacao de bots legitimos ----
# Sinaliza crawlers reconhecidos via flag ALLOW_BOT. Usado para:
#  (a) garantir que nenhuma regra futura neste .htaccess bloqueie bots
#  (b) pular hotlink/referer-empty checks (Googlebot envia Referer vazio)
#  (c) manter telemetria — se um dia adicionarmos deny rules, o env var
#      torna trivial excetuar os bots.
# ATENCAO: User-Agent e spoofavel. Validacao real de Googlebot exige
# reverse DNS (*.googlebot.com, *.google.com) — impossivel em .htaccess.
# Se precisar de garantia forte, fazer no app ou via firewall do hPanel.
<IfModule mod_setenvif.c>
  SetEnvIfNoCase User-Agent "Googlebot"            ALLOW_BOT=1
  SetEnvIfNoCase User-Agent "Googlebot-Image"      ALLOW_BOT=1
  SetEnvIfNoCase User-Agent "Googlebot-Mobile"     ALLOW_BOT=1
  SetEnvIfNoCase User-Agent "AdsBot-Google"        ALLOW_BOT=1
  SetEnvIfNoCase User-Agent "Mediapartners-Google" ALLOW_BOT=1
  SetEnvIfNoCase User-Agent "Bingbot"              ALLOW_BOT=1
  SetEnvIfNoCase User-Agent "DuckDuckBot"          ALLOW_BOT=1
  SetEnvIfNoCase User-Agent "facebookexternalhit"  ALLOW_BOT=1
  SetEnvIfNoCase User-Agent "Twitterbot"           ALLOW_BOT=1
  SetEnvIfNoCase User-Agent "LinkedInBot"          ALLOW_BOT=1
  SetEnvIfNoCase User-Agent "Slackbot"             ALLOW_BOT=1
  SetEnvIfNoCase User-Agent "WhatsApp"             ALLOW_BOT=1
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On

  # ---- 1. Dominio canonico + HTTPS ----
  # Ordem importa: www/dominio-incorreto primeiro evita double-hop quando o
  # cliente entra via http://www.elkysb.com.br → 1 unico 301 para https://elkys.com.br/

  # elkysb.com.br → elkys.com.br (dominio digitado errado)
  RewriteCond %{HTTP_HOST} ^(www\.)?elkysb\.com\.br$ [NC]
  RewriteRule ^(.*)$ https://elkys.com.br/$1 [R=301,L]

  # www → non-www
  RewriteCond %{HTTP_HOST} ^www\.elkys\.com\.br$ [NC]
  RewriteRule ^(.*)$ https://elkys.com.br/$1 [R=301,L]

  # Forcar HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # ---- 2. Remover trailing slash (exceto raiz) ----
  # Elimina duplicata /cases vs /cases/ que o Search Console marcava como
  # "Pagina alternativa com tag canonica adequada".
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} ^(.+)/$
  RewriteRule ^ %1 [R=301,L]

  # ---- 3. SPA rewrite LIMITADO a /portal/* ----
  # Rotas publicas sao pre-renderizadas (dist/<rota>/index.html) e servidas
  # diretamente pelo Apache DirectoryIndex — nao entram aqui. Portal (auth)
  # cai no React Router via index.html porque tem rotas dinamicas (/portal/
  # admin/clients/:id) que nao podem ser pre-geradas.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^portal(/.*)?$ /index.html [L]
</IfModule>

# ---- 4. Portal nao deve ser indexado ----
# Mesmo servindo index.html (com canonical apontando para home), o
# X-Robots-Tag a nivel HTTP impede indexacao de qualquer URL sob /portal/.
<IfModule mod_headers.c>
  <IfModule mod_setenvif.c>
    SetEnvIf Request_URI "^/portal" IS_PORTAL
    Header set X-Robots-Tag "noindex, nofollow" env=IS_PORTAL
  </IfModule>
</IfModule>

# ---- 5. 404 real para URLs desconhecidas ----
# Substitui o soft 404 anterior (qualquer URL invalida virava HTML da home
# com status 200, que o Google classificava como "Rastreada, mas nao
# indexada"). Agora URLs nao-existentes retornam 404 + pagina com noindex.
ErrorDocument 404 /404.html

# ====================================
# Seguranca
# ====================================

Options -Indexes

<FilesMatch "^\.">
  Order allow,deny
  Deny from all
</FilesMatch>

<FilesMatch "\.(env|log|sql|yml|yaml)$">
  Order allow,deny
  Deny from all
</FilesMatch>

# ====================================
# Compressao
# ====================================

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# ====================================
# Cache
# ====================================

<IfModule mod_expires.c>
  ExpiresActive On

  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"

  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"

  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"

  # HTML sempre revalida: evita servir index.html cacheado que referencia
  # chunks JS ja deletados pelo dangerous-clean-slate do deploy.
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(woff2?|ttf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(jpe?g|png|webp|svg|ico|gif|avif)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
  </FilesMatch>
</IfModule>

# ====================================
# Headers de seguranca
# ====================================

<IfModule mod_headers.c>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
</IfModule>

# ====================================
# Troubleshooting 403 Googlebot (runbook)
# ====================================
#
# Se o Search Console reportar "Bloqueado devido a acesso proibido (403)"
# OU se "Inspecionar URL > Testar URL ativo" retornar 403, este .htaccess
# ja nao tem nenhuma regra bloqueante. O 403 vem de uma camada acima:
#
# 1. hPanel > Seguranca > WAF / Firewall do site
#    - Desativar temporariamente para isolar o problema.
#    - Se sumir, reabilitar adicionando whitelist dos IPs/ASN do Google:
#      https://developers.google.com/search/apis/ipranges/googlebot.json
#
# 2. hPanel > Seguranca > Protecao Hotlink
#    - Se ativada, pode bloquear requests sem Referer (Googlebot envia
#      Referer vazio). Desativar ou incluir elkys.com.br na whitelist.
#
# 3. hPanel > Seguranca > "Force HTTPS" duplicado
#    - Se a Hostinger estiver forcando HTTPS no nivel de painel E este
#      .htaccess tambem, gera loop/chain que algumas versoes do Googlebot
#      marcam como 403. Manter APENAS no .htaccess (regra acima, secao 1).
#
# 4. ModSecurity via suporte Hostinger
#    - Regras OWASP CRS 3.x geram false positives em UAs nao-browser.
#      Abrir ticket pedindo whitelist por UA contendo "Googlebot" ou
#      whitelist por User-Agent exato do log de acesso.
#
# Validacao: curl -A "Googlebot/2.1 (+http://www.google.com/bot.html)" \
#              -I https://elkys.com.br/ → deve retornar 200.
