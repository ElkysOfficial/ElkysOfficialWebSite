# Configuração para staging.elys.com.br apontar para /staging

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Se o host for staging.elys.com.br
    RewriteCond %{HTTP_HOST} ^staging\.elys\.com\.br$ [NC]

    # E não estiver já na pasta staging
    RewriteCond %{REQUEST_URI} !^/staging/

    # Redireciona para a pasta staging
    RewriteRule ^(.*)$ /staging/$1 [L]
</IfModule>
