# Default: normalize line endings to LF in the repository.
# Working tree checkouts use LF as well (prettier expects LF).
* text=auto eol=lf

# Explicit text files
*.ts       text eol=lf
*.tsx      text eol=lf
*.js       text eol=lf
*.jsx      text eol=lf
*.mjs      text eol=lf
*.cjs      text eol=lf
*.json     text eol=lf
*.css      text eol=lf
*.scss     text eol=lf
*.md       text eol=lf
*.html     text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.toml     text eol=lf
*.sh       text eol=lf

# Binary files — never convert
*.png      binary
*.jpg      binary
*.jpeg     binary
*.webp     binary
*.ico      binary
*.gif      binary
*.svg      text eol=lf
*.woff     binary
*.woff2    binary
*.pdf      binary
