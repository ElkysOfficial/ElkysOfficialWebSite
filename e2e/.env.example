# ═══════════════════════════════════════════════════════════════
# Credenciais para testes E2E multi-persona
# Copie para .env e preencha com dados reais
# ═══════════════════════════════════════════════════════════════

# Admin (admin_super) — acesso total
ADMIN_EMAIL=admin@elkys.com.br
ADMIN_PASSWORD=

# Comercial — CRM, leads, propostas
COMERCIAL_EMAIL=e2e-comercial@elkys.com.br
COMERCIAL_PASSWORD=<defina-uma-senha-forte-localmente>

# Jurídico — contratos
JURIDICO_EMAIL=e2e-juridico@elkys.com.br
JURIDICO_PASSWORD=<defina-uma-senha-forte-localmente>

# Financeiro — cobranças, financeiro
FINANCEIRO_EMAIL=e2e-financeiro@elkys.com.br
FINANCEIRO_PASSWORD=<defina-uma-senha-forte-localmente>

# PO — projetos, onboarding, validação
PO_EMAIL=e2e-po@elkys.com.br
PO_PASSWORD=<defina-uma-senha-forte-localmente>

# Developer — projetos, tarefas técnicas, docs dev
DEVELOPER_EMAIL=e2e-developer@elkys.com.br
DEVELOPER_PASSWORD=<defina-uma-senha-forte-localmente>

# Designer — projetos, entregáveis visuais, docs dev
DESIGNER_EMAIL=e2e-designer@elkys.com.br
DESIGNER_PASSWORD=<defina-uma-senha-forte-localmente>

# Marketing — calendário editorial, docs M&D
MARKETING_EMAIL=e2e-marketing@elkys.com.br
MARKETING_PASSWORD=<defina-uma-senha-forte-localmente>

# Suporte — tickets, SLA
SUPORTE_EMAIL=e2e-suporte@elkys.com.br
SUPORTE_PASSWORD=<defina-uma-senha-forte-localmente>
